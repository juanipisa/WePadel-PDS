%% WePadel-PDS — Diagrama de clases BACKEND (dominio + facade + config)
%% Pegar en: https://mermaid.live  |  VS Code + ext. Mermaid  |  draw.io (Insert > Advanced > Mermaid)
%%
%% LEYENDA DE RELACIONES (multiplicidad entre comillas en cada extremo):
%%   <|--   herencia (generalizacion)
%%   <|..   implementacion (interfaz)
%%   *--    composicion   (parte no vive sin el todo)
%%   o--    agregacion    (parte puede existir aparte)
%%   -->    asociacion
%%   ..>    dependencia   (usa temporalmente / crea)
%%
%% MULTIPLICIDADES UML usadas:
%%   1       exactamente uno
%%   0..1    cero o uno (opcional)
%%   0..*    cero o muchos
%%   1..*    uno o muchos
%%   *       muchos (sin limite)

classDiagram
    direction TB

    %% ─── CONFIG ───────────────────────────────────────────
    class ConfiguracionSistema {
        <<Singleton>>
        -INSTANCIA$ ConfiguracionSistema
        -costoEnvio BigDecimal
        -conversionPuntos int
        -pesosPorPuntoGenerado BigDecimal
        -canalNotificacionDefault String
        +getInstancia() ConfiguracionSistema
        +getCostoEnvio() BigDecimal
        +getConversionPuntos() int
    }

    %% ─── FACADE ───────────────────────────────────────────
    class TiendaFacade {
        <<Facade>>
        +registrarUsuario() Usuario
        +login() Usuario
        +buscarProductos() List~Producto~
        +agregarAlCarrito()
        +confirmarCompra() Pedido
        +cambiarEstadoPedido()
        +configurarNotificacion()
        +getCatalogoRaiz() Categoria
        +getConfiguracion() ConfiguracionSistema
    }

    %% ─── USUARIOS (Herencia / POO) ────────────────────────
    class Usuario {
        <<abstract>>
        #id Long
        #nombreApellido String
        #mail String
        #password String
        +validarCredenciales() boolean
        +getRol()* RolEnum
    }
    class Cliente {
        -carrito Carrito
        -sistemaPuntos SistemaPuntos
        -historialPedidos List~Pedido~
        -preferenciaNotificacion Notificador
        +confirmarCompra() Pedido
        +agregarAlCarrito()
        +cancelarPedido()
    }
    class Administrador {
        +crearCategoria() Categoria
        +crearPaleta() Paleta
        +crearPelota() Pelota
        +cambiarEstadoPedido()
        +actualizarStock()
    }
    class RolEnum {
        <<enumeration>>
        CLIENTE
        ADMINISTRADOR
    }

    %% ─── CATALOGO (Composite + Herencia) ──────────────────
    class ComponenteCatalogo {
        <<interface>>
        <<Composite>>
        +getNombre() String
        +getProductos() List~Producto~
    }
    class Categoria {
        <<Composite>>
        -nombre String
        -hijos List~ComponenteCatalogo~
        +agregar()
        +quitar()
    }
    class Producto {
        <<abstract>>
        <<Composite>>
        #id Long
        #nombre String
        #precio BigDecimal
        #stock int
        +getDescripcionTecnica()* String
        +descontarStock()
    }
    class Paleta
    class Pelota
    class Accesorio
    class Calzado

    %% ─── CARRITO ──────────────────────────────────────────
    class Carrito {
        -items List~ItemCarrito~
        +agregarItem()
        +calcularTotal() BigDecimal
        +vaciar()
    }
    class ItemCarrito {
        -producto Producto
        -cantidad int
    }

    %% ─── PEDIDO (State + Observer) ──────────────────────
    class Pedido {
        -id Long
        -cliente Cliente
        -total BigDecimal
        -estado EstadoPedido
        -metodoPago MetodoDePago
        -observadores List~Observador~
        +confirmar()
        +marcarPagado()
        +enviar()
        +entregar()
        +cancelar()
        +cambiarEstado()
        +agregarObservador()
        +notificar()
    }
    class ItemPedido {
        -producto Producto
        -cantidad int
    }
    class EstadoPedido {
        <<interface>>
        <<State>>
        +confirmar()
        +marcarPagado()
        +enviar()
        +entregar()
        +cancelar()
        +getNombre() String
    }
    class EstadoPendiente {
        <<State>>
    }
    class EstadoPagado {
        <<State>>
    }
    class EstadoEnviado {
        <<State>>
    }
    class EstadoEntregado {
        <<State>>
    }
    class EstadoCancelado {
        <<State>>
    }
    class EstadoPedidoFactory {
        <<Simple Factory>>
        +fromNombre() EstadoPedido
    }

    %% ─── OBSERVER / NOTIFICACION ────────────────────────
    class Observador {
        <<interface>>
        <<Observer>>
        +actualizar()
    }
    class Notificador {
        <<abstract>>
        <<Observer>>
        #destinatario Cliente
        +enviar()* void
    }
    class NotificadorEmail {
        <<Observer>>
    }
    class NotificadorSMS {
        <<Observer>>
    }
    class NotificadorPush {
        <<Observer>>
    }

    %% ─── PAGO (Strategy + Simple Factory + Adapter) ───────
    class MetodoDePago {
        <<interface>>
        <<Strategy>>
        +procesarPago() ResultadoPago
    }
    class PagoTarjetaCredito {
        <<Strategy>>
    }
    class PagoTransferencia {
        <<Strategy>>
    }
    class PagoMercadoPago {
        <<Strategy>>
    }
    class ResultadoPago {
        -exitoso boolean
        -mensaje String
        -codigoTransaccion String
    }
    class MetodoDePagoFactory {
        <<Simple Factory>>
        +crearTarjeta() MetodoDePago
        +crearTransferencia() MetodoDePago
        +crearMercadoPago() MetodoDePago
        +reconstruirStub() MetodoDePago
        +resolverTipo() TipoMetodoPago
    }
    class TipoMetodoPago {
        <<enumeration>>
        TARJETA
        TRANSFERENCIA
        MERCADO_PAGO
    }
    class MercadoPagoAdapter {
        <<Adapter>>
        -pasarela PasarelaPagoExterna
        -alias String
    }
    class PasarelaPagoExterna {
        <<interface>>
        +cobrar()
    }

    %% ─── PUNTOS ───────────────────────────────────────────
    class SistemaPuntos {
        -cantidad int
        -conversion int
        +getSaldo() int
        +calcularDescuento() BigDecimal
        +sumarPuntos()
        +restarPuntos()
    }

    %% ─── RELACIONES HERENCIA (sin multiplicidad) ───────────
    Usuario <|-- Cliente
    Usuario <|-- Administrador
    Usuario "1" --> "1" RolEnum : rol

    ComponenteCatalogo <|.. Categoria
    ComponenteCatalogo <|.. Producto
    Producto <|-- Paleta
    Producto <|-- Pelota
    Producto <|-- Accesorio
    Producto <|-- Calzado

    EstadoPedido <|.. EstadoPendiente
    EstadoPedido <|.. EstadoPagado
    EstadoPedido <|.. EstadoEnviado
    EstadoPedido <|.. EstadoEntregado
    EstadoPedido <|.. EstadoCancelado

    Observador <|.. Notificador
    Notificador <|-- NotificadorEmail
    Notificador <|-- NotificadorSMS
    Notificador <|-- NotificadorPush

    MetodoDePago <|.. PagoTarjetaCredito
    MetodoDePago <|.. PagoTransferencia
    MetodoDePago <|.. PagoMercadoPago
    MetodoDePago <|.. MercadoPagoAdapter

    %% ─── FACADE y SINGLETON ───────────────────────────────
    TiendaFacade "1" ..> "0..*" Usuario : orquesta
    TiendaFacade "1" ..> "0..*" Cliente
    TiendaFacade "1" ..> "0..*" Administrador
    TiendaFacade "1" ..> "0..*" Pedido
    TiendaFacade "1" ..> "0..*" Categoria
    TiendaFacade "1" ..> "0..*" Producto
    TiendaFacade "1" ..> "0..*" MetodoDePago
    TiendaFacade "1" ..> "0..*" Notificador
    TiendaFacade "1" ..> "1" ConfiguracionSistema

    %% ─── CLIENTE, CARRITO, PUNTOS ───────────────────────
    Cliente "1" *-- "1" Carrito : posee
    Cliente "1" *-- "1" SistemaPuntos : posee
    Cliente "1" o-- "0..*" Pedido : historial
    Cliente "1" --> "0..1" Notificador : preferencia
    Cliente "0..*" ..> "1" ConfiguracionSistema : consulta
    Cliente "0..*" ..> "1" MetodoDePago : usa al comprar

    Carrito "1" *-- "0..*" ItemCarrito : contiene
    ItemCarrito "0..*" --> "1" Producto : referencia

    %% ─── CATALOGO (COMPOSITE) ───────────────────────────
    Categoria "1" o-- "0..*" ComponenteCatalogo : hijos
    Producto "0..*" --> "1" Categoria : pertenece

    %% ─── PEDIDO (STATE + OBSERVER) ───────────────────────
    Pedido "1" *-- "1..*" ItemPedido : contiene
    Pedido "1" --> "1" EstadoPedido : estado actual
    Pedido "1" --> "1" MetodoDePago : pagado con
    Pedido "1" o-- "0..*" Observador : suscriptos

    Notificador "0..*" --> "1" Cliente : destinatario

    %% ─── PAGO (STRATEGY + ADAPTER + FACTORY) ────────────
    MetodoDePago "0..*" ..> "1" ResultadoPago : retorna
    MercadoPagoAdapter "0..*" --> "1" PasarelaPagoExterna : adapta

    MetodoDePagoFactory "1" ..> "0..*" MetodoDePago : crea
    MetodoDePagoFactory "1" ..> "1" TipoMetodoPago : usa enum
    MetodoDePagoFactory "1" ..> "0..*" MercadoPagoAdapter : crea

    EstadoPedidoFactory "1" ..> "0..*" EstadoPedido : crea
    Administrador "0..*" ..> "1" EstadoPedidoFactory : usa

    note for TiendaFacade "Patron Facade: punto unico de acceso"
    note for ConfiguracionSistema "Patron Singleton: config global"
    note for MetodoDePago "Patron Strategy: cobro intercambiable"
    note for MetodoDePagoFactory "Simple Factory: crea la Strategy"
    note for EstadoPedido "Patron State: ciclo de vida del pedido"
    note for Pedido "Subject Observer: notifica cambios de estado"
    note for ComponenteCatalogo "Patron Composite: arbol de catalogo"
    note for MercadoPagoAdapter "Patron Adapter: pasarela externa"

    note for Cliente "1 Cliente : 1 Carrito, 1 SistemaPuntos, 0..* Pedidos"
    note for Pedido "1 Pedido : 1..* items, 1 estado, 1 pago, 0..* observadores"
    note for Categoria "Composite: 1 categoria : 0..* hijos (cat. o producto)"
